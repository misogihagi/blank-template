{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.14.2/.schema/devbox.schema.json",
  "packages": [
    "editorconfig-checker@latest",
    "typos@latest",
    "lefthook@latest",
    "bun@latest",
    "eclint@latest",
    "yamllint@latest",
    "check-jsonschema@latest",
    "actionlint@latest",
    "ghalint@latest",
    "zizmor@latest"
  ],
  "shell": {
    "init_hook": [
      "echo 'Welcome to devbox!' > /dev/null",
      "lefthook install",
      "bun install",
      "bun run rulesync generate --targets \"*\" --features \"*\""
    ],
    "scripts": {
      "check": [
        "bun run cspell .",
        "typos .",
        "bun run secretlint \"**/*\"",
        "bun run markdownlint-cli2 docs/",
        "bun run textlint docs/",
        "eclint --exclude node_modules/",
        "yamllint -d .yamllintrc.yml .",
        "devbox run check-jsonschema",
        "actionlint",
        "ghalint run",
        "zizmor ."
      ],
      "commitlint": [
        "bun run commitlint --edit"
      ],
      "check-jsonschema": [
        "check-jsonschema --builtin-schema vendor.github-workflows .github/workflows/*",
        "check-jsonschema --schemafile .jsonschema/cspell.schema.json cspell.json ",
        "check-jsonschema --schemafile .jsonschema/devbox.schema.json devbox.json",
        "check-jsonschema --schemafile .jsonschema/lefthook.schema.json lefthook.yml",
        "check-jsonschema --schemafile .jsonschema/package.schema.json package.json",
        "check-jsonschema --schemafile .jsonschema/yamllint.json .yamllintrc.yml"
      ],
      "test": [
        "echo \"Error: no test specified\" && exit 1"
      ]
    }
  }
}
