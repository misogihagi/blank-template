{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.14.2/.schema/devbox.schema.json",
  "packages": [
    "editorconfig-checker@latest",
    "typos@latest",
    "lefthook@latest",
    "bun@latest",
    "eclint@latest",
    "yamllint@latest",
    "check-jsonschema@latest"
  ],
  "shell": {
    "init_hook": [
      "echo 'Welcome to devbox!' > /dev/null",
      "lefthook install",
      "bun install",
      "bun run rulesync generate --targets \"*\" --features \"*\""
    ],
    "scripts": {
      "check": [
        "bun run cspell .",
        "typos .",
        "bun run secretlint \"**/*\"",
        "bun run markdownlint-cli2 docs/",
        "bun run textlint docs/",
        "eclint --exclude node_modules/",
        "yamllint -d .yamllintrc.yml ."
      ],
      "commitlint": [
        "bun run commitlint --edit"
      ],
      "test": [
        "echo \"Error: no test specified\" && exit 1"
      ]
    }
  }
}
